# Uncomment this line to define a global platform for your project
platform :ios, '14.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

# Ensure Chainway RFIDManager.xcframework is present (Codemagic / fresh clones).
framework_path = File.join(__dir__, 'Frameworks', 'RFIDManager.xcframework')
scripts_framework = File.join(__dir__, 'scripts', 'Frameworks', 'RFIDManager.xcframework')
unless File.directory?(framework_path)
  if File.directory?(scripts_framework)
    FileUtils.mkdir_p(File.join(__dir__, 'Frameworks'))
    FileUtils.ln_sf('../scripts/Frameworks/RFIDManager.xcframework', framework_path)
  else
    fetch_script = File.join(__dir__, 'scripts', 'fetch_rfid_sdk.sh')
    system('bash', fetch_script) or raise 'Failed to download RFIDManager.xcframework'
  end
end

target 'Runner' do
  use_frameworks! :linkage => :static
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  pod 'RFIDManagerSDK', :path => '.'

  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      if config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'].to_f < 14.0
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '14.0'
      end
      # Match Flutter Generated.xcconfig so all pods use the same simulator arch.
      config.build_settings['EXCLUDED_ARCHS[sdk=iphonesimulator*]'] = 'i386 arm64'
      definitions = config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] || ['$(inherited)']
      %w[
        PERMISSION_CAMERA=1
        PERMISSION_PHOTOS=1
        PERMISSION_LOCATION=1
        PERMISSION_BLUETOOTH=1
      ].each do |definition|
        definitions << definition unless definitions.include?(definition)
      end
      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] = definitions
    end
  end
  installer.pods_project.build_configurations.each do |config|
    config.build_settings['EXCLUDED_ARCHS[sdk=iphonesimulator*]'] = 'i386 arm64'
  end
  # MLKit and Flutter plugins ship conflicting EXCLUDED_ARCHS values; unify Pods-Runner.
  installer.aggregate_targets.each do |aggregate_target|
    aggregate_target.xcconfigs.each do |config_name, xcconfig|
      xcconfig.attributes['EXCLUDED_ARCHS[sdk=iphonesimulator*]'] = 'i386 arm64'
      xcconfig.save_as(Pathname.new(aggregate_target.xcconfig_path(config_name)))
    end
  end
end
